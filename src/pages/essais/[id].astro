---
import Base from '../../layouts/Base.astro';
import Video from '../../components/Video.astro';
import { getCollection, render } from 'astro:content';
import { formaterDate, tempsLecture } from '../../utils/lecture';

export async function getStaticPaths() {
  const articles = await getCollection('essais', ({ data }) => !data.brouillon);
  return articles.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const lecture = tempsLecture(article.body ?? '');
---

<Base titre={article.data.titre} description={article.data.description}>
  <article class="pc-article">
    <header class="pc-lecture pc-article-entete">
      <a href="/essais" class="pc-retour">← Essais</a>
      <h1>{article.data.titre}</h1>
      <div class="pc-article-meta">
        <time class="pc-meta" datetime={article.data.date.toISOString()}>
          {formaterDate(article.data.date)}
        </time>
        <span class="pc-sep" aria-hidden="true"></span>
        <span class="pc-meta">{lecture}</span>
      </div>
    </header>

    <div class="pc-lecture pc-prose" data-numerotation>
      <Content components={{ Video }} />
    </div>

    <footer class="pc-lecture pc-article-pied">
      <span class="pc-point-fin" aria-hidden="true"></span>
      <a href="/essais" class="pc-retour">← Tous les essais</a>
    </footer>
  </article>
</Base>

<style>
  .pc-article { padding-top: 2.5rem; }
  .pc-retour {
    border: none;
    font-family: var(--pc-util);
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--pc-gris);
  }
  .pc-retour:hover { color: var(--pc-accent); }

  .pc-article-entete {
    margin-bottom: 2.5rem;
  }
  .pc-article-entete h1 {
    margin-top: 1.2rem;
    margin-bottom: 0.9rem;
  }
  .pc-article-meta {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .pc-sep {
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--pc-gris); display: inline-block;
  }

  /* Le corps de l'article hérite des styles globaux ; on règle juste l'espacement */
  .pc-prose :global(h2) { margin-top: 2.4em; }
  .pc-prose :global(h3) { margin-top: 1.8em; }
  .pc-prose :global(figure) { margin-left: 0; margin-right: 0; }

  .pc-article-pied {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--pc-trait);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }
  .pc-point-fin {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--pc-accent);
  }

  /* Numérotation des lignes (éditions critiques) : chiffres en marge */
  .pc-prose { position: relative; }
  .pc-prose :global(.pc-num-ligne) {
    position: absolute;
    left: -0.8rem;
    transform: translateX(-100%);
    font-family: var(--pc-util);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--pc-gris);
    opacity: 0.75;
    user-select: none;
    pointer-events: none;
  }
  /* Sans marge disponible, on masque la numérotation */
  @media (max-width: 860px) {
    .pc-prose :global(.pc-num-ligne) { display: none; }
  }
</style>

<script>
  // Numérote la prose toutes les 5 lignes, comme dans une édition critique.
  // Les lignes sont celles du rendu réel : la numérotation est recalculée
  // au chargement des polices et au redimensionnement.
  const PAS = 5;

  function numeroter() {
    const prose = document.querySelector<HTMLElement>('[data-numerotation]');
    if (!prose) return;

    prose.querySelectorAll('.pc-num-ligne').forEach((n) => n.remove());

    const blocs = prose.querySelectorAll<HTMLElement>(
      ':scope > p, :scope > blockquote > p, :scope > ul > li, :scope > ol > li'
    );
    const refProse = prose.getBoundingClientRect();
    let compteur = 0;

    for (const bloc of blocs) {
      const style = getComputedStyle(bloc);
      const hLigne = parseFloat(style.lineHeight);
      if (!hLigne || Number.isNaN(hLigne)) continue;

      const rect = bloc.getBoundingClientRect();
      const hTexte =
        rect.height -
        parseFloat(style.paddingTop) -
        parseFloat(style.paddingBottom);
      const nbLignes = Math.max(1, Math.round(hTexte / hLigne));

      for (let l = 1; l <= nbLignes; l++) {
        compteur++;
        if (compteur % PAS !== 0) continue;
        const num = document.createElement('span');
        num.className = 'pc-num-ligne';
        num.textContent = String(compteur);
        num.setAttribute('aria-hidden', 'true');
        const y =
          rect.top - refProse.top +
          parseFloat(style.paddingTop) +
          (l - 1) * hLigne;
        num.style.top = `${y}px`;
        prose.appendChild(num);
      }
    }
  }

  let attente: number;
  function replanifier() {
    clearTimeout(attente);
    attente = window.setTimeout(numeroter, 150);
  }

  if (document.fonts?.ready) {
    document.fonts.ready.then(numeroter);
  } else {
    numeroter();
  }
  window.addEventListener('resize', replanifier);
  window.addEventListener('load', numeroter);
</script>
